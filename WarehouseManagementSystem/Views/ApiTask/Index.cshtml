@{
    ViewData["Title"] = "API任务管理";
}

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">API任务列表</h5>
            <div>
              @*   <button type="button" class="btn btn-sm btn-light" onclick="location.href='@Url.Action("ApiTest", "ApiTask")'">
                    <i class="fas fa-plug"></i> API接口测试
                </button> *@
                <button type="button" class="btn btn-sm btn-light" onclick="refreshData()">
                    <i class="fas fa-sync-alt"></i> 刷新
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>任务编号</th>
                            <th>任务类型</th>
                            <th>执行状态</th>
                            <th>创建时间</th>
                            <th>上位机回复</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody id="taskTableBody">
                        <!-- 数据将通过JS加载 -->
                    </tbody>
                </table>
            </div>
            
            <!-- 分页控件 -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div>
                    共 <span id="totalItems">0</span> 条记录，当前第 <span id="currentPage">1</span>/<span id="totalPages">1</span> 页
                </div>
                <div>
                    <div class="btn-group">
                        <button type="button" class="btn btn-outline-primary" id="btnPrevPage" onclick="prevPage()">
                            <i class="fas fa-chevron-left"></i> 上一页
                        </button>
                        <button type="button" class="btn btn-outline-primary" id="btnNextPage" onclick="nextPage()">
                            下一页 <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 当前页码和页大小
        let currentPage = 1;
        const pageSize = 20;
        
        // 页面加载完成后获取数据
        $(document).ready(function() {
            loadData();
        });
        
        // 加载数据
        function loadData() {
            $.ajax({
                url: '@Url.Action("GetPagedTasks", "ApiTask")',
                type: 'GET',
                data: {
                    pageIndex: currentPage,
                    pageSize: pageSize
                },
                success: function(result) {
                    if (result.success) {
                        renderTable(result.data);
                        updatePagination(result.total, result.pageIndex, result.totalPages);
                    } else {
                        showError("加载数据失败: " + result.message);
                    }
                },
                error: function(xhr, status, error) {
                    showError("请求失败: " + error);
                }
            });
        }
        
        // 渲染表格
        function renderTable(data) {
            const tableBody = $("#taskTableBody");
            tableBody.empty();
            
            if (data.length === 0) {
                tableBody.append('<tr><td colspan="7" class="text-center">暂无数据</td></tr>');
                return;
            }
            
            data.forEach(function(item) {
                const row = $("<tr>");
                
                row.append($("<td>").text(item.id));
                row.append($("<td>").text(item.taskCode));
                row.append($("<td>").text(getTaskTypeName(item.taskType)));
                
                const statusBadge = item.excute ? 
                    '<span class="badge bg-success">已执行</span>' : 
                    '<span class="badge bg-warning">未执行</span>';
                row.append($("<td>").html(statusBadge));
                
                row.append($("<td>").text(formatDate(item.createTime)));
                row.append($("<td>").text(item.message || '-'));
                
                const actions = $("<td>");
                actions.append(`
                    <button class="btn btn-sm btn-danger" onclick="deleteTask(${item.id})">
                        <i class="fas fa-trash"></i>
                    </button>
                `);
                row.append(actions);
                
                tableBody.append(row);
            });
        }
        
        // 更新分页信息
        function updatePagination(total, current, totalPages) {
            $("#totalItems").text(total);
            $("#currentPage").text(current);
            $("#totalPages").text(totalPages);
            
            // 更新按钮状态
            $("#btnPrevPage").prop("disabled", current <= 1);
            $("#btnNextPage").prop("disabled", current >= totalPages);
        }
        
        // 上一页
        function prevPage() {
            if (currentPage > 1) {
                currentPage--;
                loadData();
            }
        }
        
        // 下一页
        function nextPage() {
            currentPage++;
            loadData();
        }
        
        // 刷新数据
        function refreshData() {
            loadData();
        }
        
        // 删除任务
        function deleteTask(id) {
            if (confirm("确定要删除此任务吗？")) {
                $.ajax({
                    url: '@Url.Action("DeleteTask", "ApiTask")',
                    type: 'POST',
                    data: { id: id },
                    success: function(result) {
                        if (result.success) {
                            loadData();
                        } else {
                            showError("删除失败: " + result.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        showError("请求失败: " + error);
                    }
                });
            }
        }
        
        // 格式化日期
        function formatDate(dateString) {
            if (!dateString) return '-';
            const date = new Date(dateString);
            return date.toLocaleString('zh-CN');
        }
        
        // 获取任务类型名称
        function getTaskTypeName(taskType) {
            const taskTypes = {
                1: "HTTP请求",
                2: "WebSocket",
                3: "TCP/IP",
                4: "UDP",
                5: "其他"
            };
            
            return taskTypes[taskType] || `未知类型(${taskType})`;
        }
        
        // 显示错误信息
        function showError(message) {
            alert(message);
        }
    </script>
} 