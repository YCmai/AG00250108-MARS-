    <!-- 系统日志面板 -->
    <div id="logsPanel" class="logs-panel">
        <div class="logs-panel-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">
                        <i class="fas fa-clipboard-list me-2"></i>System Logs
                    </h6>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <div class="btn-group btn-group-sm">
                        <button type="button" class="btn btn-outline-secondary logs-filter-btn active" data-level="ALL">All</button>
                        <button type="button" class="btn btn-outline-info logs-filter-btn" data-level="INF">Info</button>
                        <button type="button" class="btn btn-outline-warning logs-filter-btn" data-level="WRN">Warning</button>
                        <button type="button" class="btn btn-outline-danger logs-filter-btn" data-level="ERR">Error</button>
                        <button type="button" class="btn btn-outline-secondary logs-filter-btn" data-level="DBG">Debug</button>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clearLogsBtn" title="Clear Logs" style="padding: 4px 8px;">
                        <i class="fas fa-trash"></i> Clear
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="closeLogsBtn" title="Close Log Panel" style="padding: 4px 8px;">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>
        </div>
        <div class="logs-panel-body">
            <div id="logsContent" class="logs-content">
                <div class="text-center text-muted py-3">
                    <i class="fas fa-spinner fa-spin"></i> Loading logs...
                </div>
            </div>
        </div>
