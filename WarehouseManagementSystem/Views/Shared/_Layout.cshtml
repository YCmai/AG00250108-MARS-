    @await RenderSectionAsync("Scripts", required: false)
  
    <script>
        // Update system clock
        function updateClock() {
            const now = new Date();
            const clockElement = document.getElementById('system-clock');
            if (clockElement) {
                clockElement.innerText = now.toLocaleTimeString('zh-CN', { hour12: false });
            }
        }

        // Initialize
        setInterval(updateClock, 1000);
        updateClock();

        // System log panel functionality
        (function() {
            const logsPanel = document.getElementById('logsPanel');
            const toggleLogsBtn = document.getElementById('toggleLogsBtn');
            const closeLogsBtn = document.getElementById('closeLogsBtn');
            const clearLogsBtn = document.getElementById('clearLogsBtn');
            const logsContent = document.getElementById('logsContent');
            const contentWrapper = document.querySelector('.content-wrapper');
            const filterBtns = document.querySelectorAll('.logs-filter-btn');
            
            let isLogsPanelOpen = false;
            let autoRefreshInterval = null;
            let currentFilter = 'ALL';
            let autoScroll = true;
            let lastLogCount = 0;
            let lastFilter = 'ALL'; // 记录上一次的过滤器
            let forceUpdate = false; // 强制更新标志

            // Toggle log panel
            toggleLogsBtn.addEventListener('click', function() {
                isLogsPanelOpen = !isLogsPanelOpen;
                if (isLogsPanelOpen) {
                    logsPanel.classList.add('show');
                    contentWrapper.classList.add('logs-panel-open');
                    startAutoRefresh();
                    loadLogs();
                } else {
                    logsPanel.classList.remove('show');
                    contentWrapper.classList.remove('logs-panel-open');
                    stopAutoRefresh();
                }
            });

            // Close log panel
            closeLogsBtn.addEventListener('click', function() {
                isLogsPanelOpen = false;
                logsPanel.classList.remove('show');
                contentWrapper.classList.remove('logs-panel-open');
                stopAutoRefresh();
            });

            // Clear logs
            clearLogsBtn.addEventListener('click', function() {
                if (confirm('Are you sure you want to clear the log display?')) {
                    logsContent.innerHTML = '';
                    lastLogCount = 0;
                }
            });

            // Filter buttons
            filterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    filterBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    const newFilter = this.getAttribute('data-level');
                    lastFilter = currentFilter;
                    currentFilter = newFilter;
                    // Reset lastLogCount, force update display
                    lastLogCount = 0;
                    forceUpdate = true; // Set force update flag
                    // Reload logs
                    loadLogs();
                });
            });

            // Load logs
            async function loadLogs() {
                try {
                    const response = await fetch('/Logs/GetLatestLogs');
                    if (!response.ok) {
                        throw new Error('Failed to get logs: ' + response.status);
                    }

                    const result = await response.json();
                    if (result.success && result.data) {
                        updateLogsDisplay(result.data);
                    } else {
                        if (logsContent.innerHTML.includes('Loading logs')) {
                            logsContent.innerHTML = '<div class="text-center text-muted py-3">Failed to load logs: ' + (result.message || 'Unknown error') + '</div>';
                        }
                    }
                } catch (error) {
                    if (logsContent.innerHTML.includes('Loading logs') || logsContent.innerHTML.includes('No log data')) {
                        logsContent.innerHTML = '<div class="text-center text-muted py-3">Failed to load logs: ' + error.message + '</div>';
                    }
                }
            }

            // Update log display (directly display raw logs returned from backend, no standardization)
            function updateLogsDisplay(logs) {
                if (!logs || !Array.isArray(logs)) {
                    if (logsContent.innerHTML.includes('Loading logs')) {
                        logsContent.innerHTML = '<div class="text-center text-muted py-3">No log data available</div>';
                    }
                    return;
                }

                // Directly use data returned from backend, no processing
                const processedLogs = logs.map(log => {
                    // Directly use fields returned from backend, no standardization
                    const level = (log.level || log.Level || '').toString().trim();
                    const timestamp = log.timestamp || log.Timestamp;
                    const message = (log.message || log.Message || '').toString().trim();
                    
                    return {
                        level: level,
                        timestamp: timestamp ? new Date(timestamp) : new Date(),
                        message: message
                    };
                });

                // Check if there are new logs
                const hasNewLogs = processedLogs.length !== lastLogCount;
                const filterChanged = lastFilter !== currentFilter;
                
                // If filter is switched, must force update
                if (forceUpdate || filterChanged) {
                    forceUpdate = false;
                    lastFilter = currentFilter;
                    lastLogCount = 0;
                } else if (!hasNewLogs && lastLogCount > 0 && processedLogs.length > 0) {
                    // If count is same and filter not switched, check if first log timestamp is updated
                    const firstLog = processedLogs[0];
                    const currentFirstLog = logsContent.querySelector('.log-entry:first-child');
                    if (currentFirstLog && firstLog) {
                        const currentTimestamp = currentFirstLog.querySelector('.log-timestamp')?.textContent;
                        const newTimestamp = formatTimestamp(firstLog.timestamp);
                        if (currentTimestamp === newTimestamp) {
                            return; // No new logs, skip update
                        }
                    }
                }
                
                lastLogCount = processedLogs.length;

                // Simple filter: if ALL selected, show all logs; otherwise only show matching level (case insensitive)
                let filteredLogs;
                if (currentFilter === 'ALL' || currentFilter === 'all') {
                    filteredLogs = [...processedLogs];
                } else {
                    filteredLogs = processedLogs.filter(log => {
                        const logLevel = (log.level || '').toUpperCase();
                        const filterLevel = currentFilter.toUpperCase();
                        return logLevel === filterLevel;
                    });
                }

                // Reverse array, put newest at bottom (backend returns reverse order, newest at top)
                const reversedLogs = [...filteredLogs].reverse();

                // Save scroll position
                const wasAtBottom = isScrolledToBottom();

                // Update content
                if (reversedLogs.length === 0) {
                    logsContent.innerHTML = '<div class="text-center text-muted py-3">No log data available</div>';
                } else {
                    const maxMessageLength = 200; // Maximum display length
                    logsContent.innerHTML = reversedLogs.map((log, index) => {
                        const levelClass = getLogLevelClass(log.level);
                        const timestamp = formatTimestamp(log.timestamp);
                        const message = escapeHtml(log.message);
                        const messageId = `log-message-${index}`;
                        const isLong = message.length > maxMessageLength;
                        const shortMessage = isLong ? message.substring(0, maxMessageLength) + '...' : message;
                        const fullMessage = message;
                        
                        return `
                            <div class="log-entry ${levelClass}" data-level="${log.level}">
                                <span class="log-timestamp">${timestamp}</span>
                                <span class="log-level ${log.level}">${log.level}</span>
                                <span class="log-message" id="${messageId}">
                                    ${shortMessage}
                                    ${isLong ? `<button class="log-view-detail-btn" onclick="showLogDetail('${messageId}', ${index})" title="View Details">View Details</button>` : ''}
                                </span>
                            </div>
                            <div class="log-detail-modal" id="log-detail-${index}" style="display:none;">
                                <div class="log-detail-content">
                                    <div class="log-detail-header">
                                        <span>Detailed Log Information</span>
                                        <button class="log-detail-close" onclick="closeLogDetail(${index})">×</button>
                                    </div>
                                    <div class="log-detail-body">
                                        <div class="log-detail-row">
                                            <span class="log-detail-label">Time:</span>
                                            <span class="log-detail-value">${timestamp}</span>
                                        </div>
                                        <div class="log-detail-row">
                                            <span class="log-detail-label">Level:</span>
                                            <span class="log-detail-value"><span class="log-level ${log.level}">${log.level}</span></span>
                                        </div>
                                        <div class="log-detail-row">
                                            <span class="log-detail-label">Content:</span>
                                            <pre class="log-detail-message">${fullMessage}</pre>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }).join('');

                    // If previously scrolled to bottom, auto scroll to bottom (show latest logs)
                    if (wasAtBottom || autoScroll) {
                        scrollToBottom();
                    }
                }
            }

            // Check if scrolled to bottom
            function isScrolledToBottom() {
                const threshold = 50; // 50px tolerance
                return logsContent.scrollHeight - logsContent.scrollTop - logsContent.clientHeight < threshold;
            }

            // Scroll to bottom (show latest logs)
            function scrollToBottom() {
                // Use requestAnimationFrame to ensure scrolling after DOM update
                requestAnimationFrame(() => {
                    logsContent.scrollTop = logsContent.scrollHeight;
                });
            }

            // Get log level style class
            function getLogLevelClass(level) {
                const upperLevel = (level || '').toUpperCase();
                switch (upperLevel) {
                    case 'ERR':
                    case 'ERROR':
                    case 'FATAL':
                    case 'CRITICAL':
                        return 'log-error';
                    case 'WRN':
                    case 'WARN':
                    case 'WARNING':
                        return 'log-warning';
                    case 'INF':
                    case 'INFO':
                    case 'INFORMATION':
                        return 'log-info';
                    case 'DBG':
                    case 'DEBUG':
                        return 'log-info'; // Debug level also uses info style
                    case 'VRB':
                    case 'VERBOSE':
                        return 'log-info';
                    default:
                        return 'log-info';
                }
            }

            // Format timestamp
            function formatTimestamp(timestamp) {
                try {
                    const date = timestamp instanceof Date ? timestamp : new Date(timestamp);
                    if (isNaN(date.getTime())) {
                        return new Date().toLocaleString('zh-CN');
                    }
                    return date.toLocaleString('zh-CN', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit',
                        second: '2-digit',
                        fractionalSecondDigits: 3
                    });
                } catch (e) {
                    return new Date().toLocaleString('zh-CN');
                }
            }

            // HTML escape
            function escapeHtml(text) {
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            // Start auto refresh
            function startAutoRefresh() {
                stopAutoRefresh(); // Stop previous refresh first
                autoRefreshInterval = setInterval(() => {
                    if (isLogsPanelOpen) {
                        loadLogs();
                    }
                }, 2000); // Refresh every 2 seconds
            }

            // Stop auto refresh
            function stopAutoRefresh() {
                if (autoRefreshInterval) {
                    clearInterval(autoRefreshInterval);
                    autoRefreshInterval = null;
                }
            }

            // Listen for scroll events, auto scroll to bottom when user releases mouse
            let scrollTimeout = null;
            let isUserScrolling = false;
            let scrollEndTimer = null;
            let isMouseDown = false;
            
            logsContent.addEventListener('scroll', function() {
                isUserScrolling = true;
                autoScroll = isScrolledToBottom();
                
                // Clear previous timer
                if (scrollEndTimer) {
                    clearTimeout(scrollEndTimer);
                }
                
                // After user stops scrolling, if not at bottom, auto scroll to bottom
                scrollEndTimer = setTimeout(() => {
                    isUserScrolling = false;
                    if (!isMouseDown && !isScrolledToBottom()) {
                        // After user releases mouse, if not at bottom, auto scroll to bottom
                        scrollToBottom();
                        autoScroll = true;
                    } else if (isScrolledToBottom()) {
                        // User has scrolled to bottom, restore auto scroll
                        autoScroll = true;
                    }
                }, 300); // Consider user stopped scrolling after 300ms
            });
            
            // Listen for mouse down and up events
            logsContent.addEventListener('mousedown', function() {
                isMouseDown = true;
            });
            
            logsContent.addEventListener('mouseup', function() {
                isMouseDown = false;
                // After mouse release, if not at bottom, auto scroll to bottom
                setTimeout(() => {
                    if (!isMouseDown && !isScrolledToBottom()) {
                        scrollToBottom();
                        autoScroll = true;
                    }
                }, 100);
            });
            
            // Listen for touch events (mobile)
            logsContent.addEventListener('touchstart', function() {
                isMouseDown = true;
            });
            
            logsContent.addEventListener('touchend', function() {
                isMouseDown = false;
                setTimeout(() => {
                    if (!isMouseDown && !isScrolledToBottom()) {
                        scrollToBottom();
                        autoScroll = true;
                    }
                }, 100);
            });

            // Global function: show log details
            window.showLogDetail = function(messageId, index) {
                const modal = document.getElementById(`log-detail-${index}`);
                if (modal) {
                    modal.style.display = 'flex';
                }
            };

            // Global function: close log details
            window.closeLogDetail = function(index) {
                const modal = document.getElementById(`log-detail-${index}`);
                if (modal) {
                    modal.style.display = 'none';
                }
            };

            // Click outside modal to close
            document.addEventListener('click', function(e) {
                if (e.target.classList.contains('log-detail-modal')) {
                    e.target.style.display = 'none';
                }
            });
        })();
    </script>
</body>
</html>