@{
    ViewData["Title"] = "数据库连接测试";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 仓库管理系统</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/all.min.css" />
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h4><i class="fas fa-database me-2"></i>数据库连接测试</h4>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(ViewBag.Message))
                        {
                            <div class="alert @(ViewBag.Message.Contains("成功") ? "alert-success" : "alert-danger")">
                                <h5>@ViewBag.Message</h5>
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(ViewBag.ConnectionString))
                        {
                            <div class="mb-3">
                                <label class="form-label">连接字符串：</label>
                                <textarea class="form-control" rows="3" readonly>@ViewBag.ConnectionString</textarea>
                            </div>
                        }
                        
                        @if (ViewBag.TestResult != null)
                        {
                            <div class="mb-3">
                                <label class="form-label">测试结果：</label>
                                <input type="text" class="form-control" value="@ViewBag.TestResult" readonly />
                            </div>
                        }
                        
                        @if (!string.IsNullOrEmpty(ViewBag.Error))
                        {
                            <div class="mb-3">
                                <label class="form-label">错误详情：</label>
                                <textarea class="form-control" rows="10" readonly>@ViewBag.Error</textarea>
                            </div>
                        }
                        
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("Index", "Database")" class="btn btn-primary">
                                <i class="fas fa-sync me-1"></i>重新测试连接
                            </a>
                            <a href="@Url.Action("CreateTables", "Database")" class="btn btn-success">
                                <i class="fas fa-table me-1"></i>创建数据库表
                            </a>
                            <a href="@Url.Action("Login", "Auth")" class="btn btn-info">
                                <i class="fas fa-sign-in-alt me-1"></i>返回登录页面
                            </a>
                        </div>
                        
                        <div class="mt-4">
                            <h5>默认管理员账户：</h5>
                            <p><strong>用户名：</strong> admin</p>
                            <p><strong>密码：</strong> admin123</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
