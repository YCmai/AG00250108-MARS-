@model WarehouseManagementSystem.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Warehouse Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/all.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .login-container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
            padding: 40px;
            width: 100%;
            max-width: 400px;
            position: relative;
            overflow: hidden;
        }
        
        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }
        
        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .login-header h2 {
            color: #333;
            font-weight: 600;
            margin-bottom: 10px;
        }
        
        .login-header p {
            color: #666;
            font-size: 14px;
        }
        
        .form-group {
            margin-bottom: 20px;
            position: relative;
        }
        
        .form-group label {
            color: #555;
            font-weight: 500;
            margin-bottom: 8px;
            display: block;
        }
        
        .input-group {
            position: relative;
        }
        
        .input-group-text {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-right: none;
            color: #6c757d;
        }
        
        .form-control {
            border: 1px solid #e9ecef;
            border-left: none;
            padding: 12px 15px;
            font-size: 14px;
            transition: all 0.3s ease;
        }
        
        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }
        
        .btn-login {
            background: linear-gradient(135deg, #667eea, #764ba2);
            border: none;
            color: white;
            padding: 12px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 8px;
            width: 100%;
            transition: all 0.3s ease;
            margin-top: 10px;
        }
        
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
        }
        
        .form-check {
            margin: 20px 0;
        }
        
        .form-check-input:checked {
            background-color: #667eea;
            border-color: #667eea;
        }
        
        .alert {
            border-radius: 8px;
            border: none;
            padding: 12px 15px;
            margin-bottom: 20px;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
        }
        
        .text-danger {
            color: #dc3545;
            font-size: 12px;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h2><i class="fas fa-warehouse"></i> Warehouse Management System</h2>
            <p>Please enter your login credentials</p>
        </div>
        
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }
        
        <form id="loginForm">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            
            <div class="form-group">
                <label for="Username">Username</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-user"></i>
                    </span>
                    <input type="text" id="Username" name="Username" class="form-control" placeholder="Enter username" required />
                </div>
                <div id="username-error" class="text-danger"></div>
            </div>
            
            <div class="form-group">
                <label for="Password">Password</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input type="password" id="Password" name="Password" class="form-control" placeholder="Enter password" required />
                </div>
                <div id="password-error" class="text-danger"></div>
            </div>
            
            <div class="form-check">
                <input type="checkbox" id="RememberMe" name="RememberMe" class="form-check-input" />
                <label for="RememberMe" class="form-check-label">
                    Remember me
                </label>
            </div>
            
            <button type="button" id="loginBtn" class="btn btn-login">
                <i class="fas fa-sign-in-alt"></i> Login
            </button>
        </form>
        
        <div id="login-result" class="mt-3"></div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            console.log('Login page loaded');
            
            var isSubmitting = false; // Prevent duplicate submission flag
            
            // Ensure button exists before binding event
            if ($('#loginBtn').length > 0) {
                console.log('Login button found, binding click event');
                
                // Use button click event instead of form submit event
                $('#loginBtn').off('click').on('click', function(e) {
                    console.log('Login button click event triggered!');
                    e.preventDefault();
                
                // Prevent duplicate submission
                if (isSubmitting) {
                    console.log('Submission in progress, ignoring duplicate click');
                    return false;
                }
                
                console.log('Login button clicked, starting AJAX login');
                
                var username = $('#Username').val();
                var password = $('#Password').val();
                var rememberMe = $('#RememberMe').is(':checked');
                var returnUrl = $('input[name="returnUrl"]').val();
                
                // If ReturnUrl is root path, set to empty to let backend use default value
                if (returnUrl === '/' || returnUrl === '') {
                    returnUrl = '';
                }
                
                // Basic validation
                if (!username || !password) {
                    $('#login-result').html('<div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Please enter username and password</div>');
                    return false;
                }
                
                console.log('Login info:', {
                    username: username,
                    password: password ? 'entered' : 'not entered',
                    rememberMe: rememberMe,
                    returnUrl: returnUrl
                });
                
                // Set submission status
                isSubmitting = true;
                
                // Clear previous error messages
                $('#username-error, #password-error').text('');
                $('#login-result').html('');
                
                // Show loading status and disable button
                $('#login-result').html('<div class="alert alert-info"><i class="fas fa-spinner fa-spin"></i> Logging in...</div>');
                $('#loginBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Logging in...');
                
                $.ajax({
                    url: '/Auth/AjaxLogin',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        Username: username,
                        Password: password,
                        RememberMe: rememberMe,
                        ReturnUrl: returnUrl
                    }),
                    success: function(response) {
                        console.log('Login successful:', response);
                        $('#login-result').html('<div class="alert alert-success"><i class="fas fa-check"></i> ' + response.message + '</div>');
                        
                        if (response.success) {
                            setTimeout(function() {
                                // Ensure redirect to correct page, avoid root path
                                var targetUrl = response.redirectUrl;
                                if (!targetUrl || targetUrl === '/' || targetUrl === '') {
                                    targetUrl = '/DisplayLocation/Index';
                                }
                                window.location.href = targetUrl;
                            }, 1500);
                        } else {
                            // Login failed, restore button status
                            isSubmitting = false;
                            $('#loginBtn').prop('disabled', false).html('<i class="fas fa-sign-in-alt"></i> Login');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.log('Login failed:', xhr.responseText);
                        var errorMessage = 'Login failed, please try again';
                        
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMessage = xhr.responseJSON.message;
                        } else if (xhr.status === 401) {
                            errorMessage = 'Invalid username or password';
                        } else if (xhr.status === 400) {
                            errorMessage = 'Invalid input data';
                        }
                        
                        $('#login-result').html('<div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> ' + errorMessage + '</div>');
                        
                        // Restore button status
                        isSubmitting = false;
                        $('#loginBtn').prop('disabled', false).html('<i class="fas fa-sign-in-alt"></i> Login');
                    },
                    complete: function() {
                        // Ensure state is reset after request completes (fallback mechanism)
                        setTimeout(function() {
                            isSubmitting = false;
                            $('#loginBtn').prop('disabled', false).html('<i class="fas fa-sign-in-alt"></i> Login');
                        }, 2000);
                    }
                });
                
                return false; // Ensure default submission is not triggered
                });
            } else {
                console.log('Login button not found!');
            }

            // Support Enter key for login
            $('#loginForm').on('keypress', function(e) {
                if (e.which === 13) { // Enter key
                    e.preventDefault();
                    $('#loginBtn').click();
                }
            });
        });
    </script>
</body>
</html>
