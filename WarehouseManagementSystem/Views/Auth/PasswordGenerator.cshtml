@{
    ViewData["Title"] = "Password Hash Generator";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Password Hash Generator</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h4><i class="fas fa-key"></i> Password Hash Generator</h4>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <strong>Password Encoding Standard:</strong> SHA256 Hash + Base64 Encoding
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Enter Password</label>
                            <input type="text" id="passwordInput" class="form-control" placeholder="Enter password to generate hash" />
                        </div>
                        
                        <button id="generateHash" class="btn btn-primary">
                            <i class="fas fa-cog"></i> Generate Hash
                        </button>
                        
                        <div id="hashResult" class="mt-3"></div>
                        
                        <hr />
                        
                        <h5>Common Password Hashes</h5>
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Password</th>
                                        <th>SHA256+Base64 Hash</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><code>admin123</code></td>
                                        <td><code>JAv1GPq9JyTdtvB06x211nRI1+gxwIyPqCKAn3THIKk=</code></td>
                                        <td><button class="btn btn-sm btn-outline-primary" onclick="copyHash('JAv1GPq9JyTdtvB06x211nRI1+gxwIyPqCKAn3THIKk=')">Copy</button></td>
                                    </tr>
                                    <tr>
                                        <td><code>123456</code></td>
                                        <td><code>e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855</code></td>
                                        <td><button class="btn btn-sm btn-outline-primary" onclick="copyHash('e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855')">Copy</button></td>
                                    </tr>
                                    <tr>
                                        <td><code>password</code></td>
                                        <td><code>XohImNooBHFR0OVvjcYpJ3NgPQ1qq73WKhHvch0VQtg=</code></td>
                                        <td><button class="btn btn-sm btn-outline-primary" onclick="copyHash('XohImNooBHFR0OVvjcYpJ3NgPQ1qq73WKhHvch0VQtg=')">Copy</button></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        
                        <div class="mt-3">
                            <h6>SQL Update Statement Template:</h6>
                            <pre class="bg-light p-3"><code>UPDATE Users 
SET PasswordHash = 'generated_hash_value'
WHERE Username = 'username';</code></pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <script>
        $('#generateHash').click(function() {
            var password = $('#passwordInput').val();
            if (!password) {
                $('#hashResult').html('<div class="alert alert-warning">Please enter a password</div>');
                return;
            }
            
            // Use CryptoJS to calculate SHA256 hash
            var hash = CryptoJS.SHA256(password).toString(CryptoJS.enc.Base64);
            
            $('#hashResult').html(`
                <div class="alert alert-success">
                    <h6>Generation Result:</h6>
                    <p><strong>Password:</strong> <code>${password}</code></p>
                    <p><strong>SHA256+Base64 Hash:</strong></p>
                    <div class="input-group">
                        <input type="text" class="form-control" value="${hash}" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="copyHash('${hash}')">
                            <i class="fas fa-copy"></i> Copy
                        </button>
                    </div>
                    <div class="mt-2">
                        <small class="text-muted">SQL Update Statement:</small>
                        <code>UPDATE Users SET Password = '${hash}' WHERE Username = 'username';</code>
                    </div>
                </div>
            `);
        });
        
        function copyHash(hash) {
            navigator.clipboard.writeText(hash).then(function() {
                alert('Hash copied to clipboard!');
            });
        }
        
        // Enter key to generate hash
        $('#passwordInput').keypress(function(e) {
            if (e.which == 13) {
                $('#generateHash').click();
            }
        });
    </script>
</body>
</html>
