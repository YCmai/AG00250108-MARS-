@{
    ViewData["Title"] = "密码测试";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>密码测试</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4>密码哈希测试</h4>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">测试密码</label>
                            <input type="text" id="testPassword" class="form-control" value="admin123" />
                        </div>
                        <button id="testHash" class="btn btn-primary">测试哈希</button>
                        <div id="hashResult" class="mt-3"></div>
                        
                        <hr />
                        
                        <h5>数据库中的哈希值</h5>
                        <code>jGl25bVBBBW96Qi9Te4V37Fnqchz/Eu4qB9vKrRIqRg=</code>
                        
                        <hr />
                        
                        <h5>登录测试</h5>
                        <form id="loginForm">
                            <div class="mb-3">
                                <label class="form-label">用户名</label>
                                <input type="text" id="username" class="form-control" value="admin" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">密码</label>
                                <input type="password" id="password" class="form-control" value="admin123" />
                            </div>
                            <button type="submit" class="btn btn-success">登录测试</button>
                        </form>
                        <div id="loginResult" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $('#testHash').click(function() {
            var password = $('#testPassword').val();
            
            // 使用CryptoJS计算SHA256哈希
            if (typeof CryptoJS !== 'undefined') {
                var hash = CryptoJS.SHA256(password).toString(CryptoJS.enc.Base64);
                $('#hashResult').html(`
                    <div class="alert alert-info">
                        <strong>密码:</strong> ${password}<br>
                        <strong>SHA256哈希:</strong> ${hash}
                    </div>
                `);
            } else {
                $('#hashResult').html('<div class="alert alert-warning">需要CryptoJS库来计算哈希</div>');
            }
        });
        
        $('#loginForm').on('submit', function(e) {
            e.preventDefault();
            
            var username = $('#username').val();
            var password = $('#password').val();
            
            $('#loginResult').html('<div class="alert alert-info">正在测试登录...</div>');
            
            $.ajax({
                url: '/Auth/AjaxLogin',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    Username: username,
                    Password: password
                }),
                success: function(response) {
                    $('#loginResult').html(`
                        <div class="alert alert-success">
                            <strong>登录成功!</strong><br>
                            ${JSON.stringify(response)}
                        </div>
                    `);
                },
                error: function(xhr) {
                    $('#loginResult').html(`
                        <div class="alert alert-danger">
                            <strong>登录失败!</strong><br>
                            状态: ${xhr.status}<br>
                            响应: ${xhr.responseText}
                        </div>
                    `);
                }
            });
        });
    </script>
</body>
</html>
