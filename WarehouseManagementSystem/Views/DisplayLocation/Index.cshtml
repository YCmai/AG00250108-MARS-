<script>
let currentLocationId = null;
let locationModal = null;
let locationSelectorModal;
let batchImportModal;
let taskRefreshInterval;
let isTaskPanelActive = false;

document.addEventListener('DOMContentLoaded', function() {
    locationModal = new bootstrap.Modal(document.getElementById('locationDetailsModal'));
    locationSelectorModal = new bootstrap.Modal(document.getElementById('locationSelectorModal'));
    batchImportModal = new bootstrap.Modal(document.getElementById('batchImportModal'));
    
    // Add file selection listener
    document.getElementById('excelFile').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            previewExcel(file);
        }
    });
    
    // Task panel control
    document.getElementById('toggleTasksBtn').addEventListener('click', toggleTasksPanel);
    document.getElementById('closeTasksBtn').addEventListener('click', toggleTasksPanel);
    
    // Restore task panel state from localStorage
    if (localStorage.getItem('tasksPanelActive') === 'true') {
        toggleTasksPanel();
    }
});

function toggleTasksPanel() {
    const tasksPanel = document.getElementById('tasksPanel');
    const toggleBtn = document.getElementById('toggleTasksBtn');
    
    isTaskPanelActive = !isTaskPanelActive;
    
    if (isTaskPanelActive) {
        tasksPanel.classList.add('active');
        toggleBtn.innerHTML = '<i class="fas fa-tasks"></i> Hide Task List';
        refreshTasks();
        // Set auto refresh
        taskRefreshInterval = setInterval(refreshTasks, 30000); // Refresh every 30 seconds
    } else {
        tasksPanel.classList.remove('active');
        toggleBtn.innerHTML = '<i class="fas fa-tasks"></i> Show Task List';
        // Clear auto refresh
        clearInterval(taskRefreshInterval);
    }
    
    // Save state to localStorage
    localStorage.setItem('tasksPanelActive', isTaskPanelActive);
}

async function refreshTasks() {
    if (!isTaskPanelActive) return;
    
    const tasksContainer = document.getElementById('tasksContainer');
    const statusFilter = document.getElementById('taskStatusFilter').value;
    const countFilter = document.getElementById('taskCountFilter').value;
    
    try {
        // Show loading state
        tasksContainer.innerHTML = `
            <div class="text-center py-3">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2">Loading task data...</p>
            </div>
        `;
        
        // Get task data
        const response = await fetch(`/Tasks/GetRecentTasks?status=${statusFilter}&count=${countFilter}`);
        if (!response.ok) {
            throw new Error('Failed to get task data');
        }
        
        const data = await response.json();
        
        if (data.success) {
            renderTasks(data.tasks);
        } else {
            tasksContainer.innerHTML = `
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> ${data.message || 'Failed to get task data'}
                </div>
            `;
        }
    } catch (error) {
        console.error('Failed to refresh tasks:', error);
        tasksContainer.innerHTML = `
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle"></i> Failed to get task data, please try again later
            </div>
            <button class="btn btn-sm btn-outline-primary w-100" onclick="refreshTasks()">
                <i class="fas fa-sync-alt"></i> Retry
            </button>
        `;
    }
}

function renderTasks(tasks) {
    const tasksContainer = document.getElementById('tasksContainer');
    
    if (!tasks || tasks.length === 0) {
        tasksContainer.innerHTML = `
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> No task data available
            </div>
        `;
        return;
    }
    
    let html = '';
    
    tasks.forEach(task => {
        // Determine task status category
        let statusClass = 'running';
        if (task.taskStatus >= 30) { // Assume 30 is completed status
            statusClass = 'finished';
        } else if (task.taskStatus === 20) { // Assume 20 is cancelled status
            statusClass = 'canceled';
        }
        
        // Format date
        const createTime = task.creatTime ? new Date(task.creatTime).toLocaleString() : 'Unknown';
        
        // Build task item HTML
        html += `
            <div class="task-item ${statusClass}">
                <div class="task-header">
                    <div class="task-title">${task.taskType || 'Unknown Type'}</div>
                    <div class="task-status">
                        <span class="badge ${getStatusBadgeClass(task.taskStatus)}">
                            ${getStatusText(task.taskStatus)}
                        </span>
                    </div>
                </div>
                <div class="task-details">
                    <div><strong>Source:</strong> ${task.sourcePosition || 'Unknown'}</div>
                    <div><strong>Target:</strong> ${task.targetPosition || 'Unknown'}</div>
                    <div><strong>AGV:</strong> ${task.robotCode || 'Unassigned'}</div>
                    <div><strong>Created:</strong> ${createTime}</div>
                </div>
                ${task.taskStatus < 30 && !task.isCancelled ? `
                    <div class="task-action">
                        <button class="btn btn-sm btn-danger" onclick="cancelTaskFromPanel(${task.id})">
                            Cancel Task
                        </button>
                    </div>
                ` : ''}
            </div>
        `;
    });
    
    tasksContainer.innerHTML = html;
}

function getStatusBadgeClass(status) {
    // Return corresponding Badge class based on task status
    switch (status) {
        case 0: return 'bg-secondary'; // Not executed
        case 10: // Task started
        case 11: // Parameter confirmation
        case 12: // Confirm executing AGV
            return 'bg-primary';
        case 13: // Picking up
        case 15: // Unloading
            return 'bg-warning';
        case 14: // Pickup completed
        case 16: // Unload completed
            return 'bg-info';
        case 30: return 'bg-success'; // Task completed
        case 20: return 'bg-danger';  // Cancelled
        default: return 'bg-light text-dark';
    }
}

function getStatusText(status) {
    // Return corresponding text based on task status
    switch (status) {
        case 0: return 'Not Executed';
        case 1: return 'Executing';
        case 4: return 'Task Completed';
        case 8: return 'Task Cancelled';
        case 10: return 'Task Started';
        case 11: return 'Task Completed';
        case 12: return 'Confirm Executing AGV';
        case 13: return 'Picking Up';
        case 14: return 'Pickup Completed';
        case 15: return 'Unloading';
        case 16: return 'Unload Completed';
        case 30: return 'Task Cancelled';
        case 20: return 'Cancelled';
        default: return `Status ${status}`;
    }
}

async function cancelTaskFromPanel(taskId) {
    if (confirm('Are you sure you want to cancel this task?')) {
        try {
            const response = await fetch('/Tasks/CancelTask', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: `id=${taskId}`
            });
            
            if (!response.ok) {
                throw new Error('Request failed');
            }
            
            const result = await response.json();
            
            if (result.success) {
                showToast('success', result.message);
                setTimeout(() => refreshTasks(), 1000);
            } else {
                showToast('error', result.message || 'Failed to cancel task');
            }
        } catch (error) {
            console.error('Failed to cancel task:', error);
            showToast('error', 'Failed to cancel task, please try again');
        }
    }
}

function showLocationDetails(id, nodeRemark, materialCode, palletID, entryDate, quantity, group, lock, enabled) {
    currentLocationId = id;

    // Update modal content
    document.getElementById('nodeRemark').textContent = nodeRemark;
    document.getElementById('locationStatus').textContent = materialCode ? 'Occupied' : 'Available';
    document.getElementById('materialCode').textContent = materialCode || 'None';
    document.getElementById('palletID').textContent = palletID || 'None';
    document.getElementById('entryDate').textContent = entryDate || 'None';
    //document.getElementById('weight').textContent = weight || '0';
    // document.getElementById('quantity').textContent = quantity || '0';
    //document.getElementById('liftingHeight').textContent = liftingHeight || '0';
    
    // Update lock status and button text
    const isLocked = lock === 'True';
    document.getElementById('lockStatus').textContent = isLocked ? 'Locked' : 'Unlocked';
    
    // Update enabled status
    const isEnabled = enabled === 'True';
    const enabledStatusElement = document.getElementById('enabledStatus');
    if (enabledStatusElement) {
        enabledStatusElement.innerHTML = isEnabled 
            ? '<span class="badge bg-success">Enabled</span>' 
            : '<span class="badge bg-secondary">Disabled</span>';
    }
    
    // Update lock button status and text
    const lockButton = document.getElementById('lockButton');
    const lockButtonText = document.getElementById('lockButtonText');
    if (isLocked) {
        lockButton.classList.remove('btn-warning');
        lockButton.classList.add('btn-success');
        lockButtonText.textContent = 'Unlock';
        lockButton.querySelector('i').classList.remove('fa-lock');
        lockButton.querySelector('i').classList.add('fa-unlock');
    } else {
        lockButton.classList.remove('btn-success');
        lockButton.classList.add('btn-warning');
        lockButtonText.textContent = 'Lock';
        lockButton.querySelector('i').classList.remove('fa-unlock');
        lockButton.querySelector('i').classList.add('fa-lock');
    }
    
    // Show modal
    locationModal.show();
}

function createNewLocation() {
    window.location.href = '/DisplayLocation/CreateEdit';
}

function editLocation() {
    if (!currentLocationId) return;
    window.location.href = `/DisplayLocation/CreateEdit/${currentLocationId}`;
}

async function handleLocationAction(actionType) {
    if (!currentLocationId) return;
    
    let confirmMessage = '';
    switch (actionType) {
        case 1:
            confirmMessage = 'Are you sure you want to delete this location?';
            break;
        case 3:
            confirmMessage = 'Are you sure you want to clear this location?';
            break;
        case 4:
            confirmMessage = 'Are you sure you want to reset this location?';
            break;
        case 2:
            const isLocked = document.getElementById('lockStatus').textContent === 'Locked';
            confirmMessage = isLocked ? 'Are you sure you want to unlock this location?' : 'Are you sure you want to lock this location?';
            break;
    }
    
    if (confirmMessage && !confirm(confirmMessage + ' This operation cannot be undone!')) {
        return;
    }
    
    try {
        const params = new URLSearchParams({
            type: actionType.toString()
        });
        
        const response = await fetch(`/DisplayLocation/DeleteConfirmed/${currentLocationId}?${params}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        });
        
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const result = await response.json();
        
        if (result.success) {
            if (actionType === 1) {
                locationModal.hide();
            }
            // Create a Promise to wait for toast display completion
            await new Promise(resolve => {
                const toast = showToast('success', result.message);
                toast.addEventListener('shown.bs.toast', () => {
                    setTimeout(resolve, 800); // Wait for toast display 800ms
                });
            });
            window.location.reload();
        } else {
            showToast('error', result.message || 'Operation failed');
        }
    } catch (error) {
        console.error('Operation failed:', error);
        showToast('error', 'Operation failed, please try again');
    }
}

function filterLocations(searchText) {
    try {
        // Convert to lowercase for case-insensitive search
        searchText = searchText.toLowerCase();
        
        // Get current status filter value
        const statusFilter = document.getElementById('statusFilter').value;

        // Get all location elements
        const locationBoxes = document.querySelectorAll('.location-box');

        locationBoxes.forEach(box => {
            // Get location number
            const locationNumber = box.getAttribute('data-location');
            
            // Check status match
            let statusMatch = true;
            if (statusFilter !== 'all') {
                const locationInner = box.querySelector('.location-inner');
                if (statusFilter === 'occupied') {
                    // For occupied status, include purely occupied and occupied+locked locations
                    statusMatch = locationInner.classList.contains('occupied');
                } else if (statusFilter === 'locked') {
                    // For locked status, include purely locked and occupied+locked locations
                    statusMatch = locationInner.classList.contains('locked');
                } else if (statusFilter === 'empty') {
                    // For available status, must be neither occupied nor locked
                    statusMatch = locationInner.classList.contains('empty') && 
                                 !locationInner.classList.contains('occupied') && 
                                 !locationInner.classList.contains('locked');
                } else {
                    // Other statuses maintain original logic
                    statusMatch = locationInner.classList.contains(statusFilter);
                }
            }

            // If search text is empty and status matches, show location
            if (!searchText && statusMatch) {
                box.style.display = '';
                return;
            }

            // Check if location number contains search text and status matches
            if (locationNumber && locationNumber.toLowerCase().includes(searchText) && statusMatch) {
                box.style.display = '';
            } else {
                box.style.display = 'none';
            }
        });

        // Handle group show/hide
        const groups = document.querySelectorAll('.location-group');
        groups.forEach(group => {
            // Check if this group has any visible locations
            const hasVisibleLocations = Array.from(group.querySelectorAll('.location-box'))
                .some(box => box.style.display !== 'none');

            // Show/hide entire group based on whether there are visible locations
            group.style.display = hasVisibleLocations ? '' : 'none';
        });

    } catch (error) {
        console.error('Error occurred while searching locations:', error);
    }
}

function filterByStatus(status) {
    // Reapply search, which will consider status filtering simultaneously
    const searchText = document.getElementById('searchInput').value;
    filterLocations(searchText);
}

function showToast(type, message) {
    let toastContainer = document.getElementById('toastContainer');
    
    if (!toastContainer) {
        toastContainer = document.createElement('div');
        toastContainer.id = 'toastContainer';
        toastContainer.style.position = 'fixed';
        toastContainer.style.top = '20px';
        toastContainer.style.right = '20px';
        toastContainer.style.zIndex = '9999';
        document.body.appendChild(toastContainer);
    }
    
    const toast = document.createElement('div');
    toast.className = `toast align-items-center text-white bg-${type === 'success' ? 'success' : 'danger'} border-0`;
    toast.setAttribute('role', 'alert');
    toast.setAttribute('aria-live', 'assertive');
    toast.setAttribute('aria-atomic', 'true');
    
    toast.innerHTML = `
        <div class="d-flex">
            <div class="toast-body">
                ${message}
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    `;
    
    toastContainer.appendChild(toast);
    const bsToast = new bootstrap.Toast(toast);
    bsToast.show();
    
    toast.addEventListener('hidden.bs.toast', () => {
        toast.remove();
    });

    return toast;
}

function deleteLocation() {
    handleLocationAction(1);
}

function clearLocation() {
    handleLocationAction(3);
}

function resetLocation() {
    handleLocationAction(4);
}

function toggleLock() {
    handleLocationAction(2);
}

function openLocationSelectorModal() {
    locationSelectorModal.show();
}

function filterLocationsByGroup() {
    // When switching area filter, apply search conditions simultaneously
    filterLocationsBySearch();
}

function filterLocationsBySearch() {
    const searchText = document.getElementById('locationSearch').value.toLowerCase();
    const selectedGroup = document.getElementById('filterGroup').value;
    const items = document.querySelectorAll('.location-item');
    
    items.forEach(item => {
        const nodeText = item.dataset.node.toLowerCase();
        const groupMatch = !selectedGroup || item.dataset.group === selectedGroup;
        
        if (groupMatch && (!searchText || nodeText.includes(searchText))) {
            item.style.display = '';
        } else {
            item.style.display = 'none';
        }
    });
}

function toggleSelectAll() {
    const selectAll = document.getElementById('selectAllLocations').checked;
    const checkboxes = document.querySelectorAll('.location-checkbox');
    const visibleCheckboxes = Array.from(checkboxes).filter(box => 
        box.closest('.location-item').style.display !== 'none'
    );
    
    visibleCheckboxes.forEach(checkbox => {
        checkbox.checked = selectAll;
    });
}

function getSelectedLocationIds() {
    const checkboxes = document.querySelectorAll('.location-checkbox:checked');
    return Array.from(checkboxes).map(checkbox => parseInt(checkbox.value));
}

function batchClearMaterialsSelected() {
    const locationIds = getSelectedLocationIds();
    
    if (locationIds.length === 0) {
        alert('Please select at least one location');
        return;
    }
    
    if (!confirm(`Are you sure you want to clear materials from ${locationIds.length} selected locations? This operation cannot be undone!`)) {
        return;
    }
    
    $.ajax({
        url: '/DisplayLocation/BatchClearMaterials',
        type: 'POST',
        traditional: true,
        data: {
            locationIds: locationIds
        },
        success: function(result) {
            if (result.success) {
                alert(`${result.message}`);
                location.reload();
            } else {
                alert(`Operation failed: ${result.message}`);
            }
        },
        error: function() {
            alert('Operation request failed, please check network connection');
        }
    });
}

