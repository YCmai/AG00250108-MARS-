
<div class="row mb-3" style="margin-top:1%">
    <div class="col-sm-8 col-12">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["searchString"]" class="form-control me-2" placeholder="Enter location description" />
            <button type="submit" style="width: 5em;" class="btn btn-primary me-2">Search</button>
        </form>
    </div>
    <div class="col-sm-4 col-12 text-end mt-sm-0 mt-2">
        <a asp-action="CreateEdit" class="btn btn-success">Create Location</a>
    </div>
    <!-- Display statistics -->
   @*  <div class="row mb-3">
        <div class="col-sm-6 col-12">
            <p><strong>Storage Capacity Available:</strong> @ViewData["StorageCapacityAvailable"]</p>
        </div>
        <div class="col-sm-6 col-12">
            <p><strong>Storage Capacity Use:</strong> @ViewData["StorageCapacityUse"]</p>
        </div>
    </div> *@

</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered text-center">
        <thead class="table-light">
            <tr>
                <th>Map Node</th>
                <th>Node Remark</th>
                <th>Material Code</th>
                <th>Pickup Height</th>
                <th>Unload Height</th>
                <th>Operation Point</th>
               @*  <th>Pallet ID</th>
                <th>Material Weight</th> *@
              @*   <th>Material Quantity</th> *@
                <th>Entry Date</th>
                <th>Lock</th>
                <th>Enabled Status</th>
                <th>Operations</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                @* Check if it's an error material row *@
                var isErrorRow = item.MaterialCode != null && item.MaterialCode.Contains("Err_");
                <tr class="@(isErrorRow ? "bg-danger bg-opacity-10" : "")">
                    <td>@item.Name</td>
                    <td>@item.NodeRemark</td>
                    <td>@item.MaterialCode</td>
                    <td>@item.LiftingHeight</td>
                    <td>@item.UnloadHeight</td>
                   
                    <td>@item.WattingNode</td>
                 @*    <td>@item.PalletID</td>
                    <td>@item.Weight</td>
                    <td>@item.Quantity</td> *@
                    <td>@item.EntryDate</td>
                    <td>@item.Lock</td>
                    <td>
                        @if (item.Enabled)
                        {
                            <span class="badge bg-success">Enabled</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Disabled</span>
                        }
                    </td>
                    <td class="text-left">
                        <a asp-action="CreateEdit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                        @* <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal"
                    onclick="setDeleteInfo('@item.Id', '@item.Name',1)" class="btn btn-sm btn-danger">
                            <i class="fas fa-trash"></i> Delete
                        </a>
                        <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                           onclick="setDeleteInfo('@item.Id', '@item.Name',2)" class="btn btn-sm btn-warning">
                            <i class="fas fa-unlock"></i> Unlock
                        </a> 
                       @*  <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                           onclick="setDeleteInfo('@item.Id', '@item.Name',3)" class="btn btn-sm btn-danger">
                            <i class="fas fa-times"></i> Clear
                        </a> *@
                        @if (isErrorRow)
                        {
                            <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                               onclick="setDeleteInfo('@item.Id', '@item.Name',4)" class="btn btn-sm btn-info">
                                <i class="fas fa-redo"></i> Reset
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination navigation, displayed in bottom right -->
<div class="d-flex justify-content-end">
    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm">
             @if (Model.HasPreviousPage)
            { 
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.PageNumber - 1)&searchString=@(ViewData["searchString"])">Previous</a>
                </li>
             } 

            <li class="page-item disabled">
                <span class="page-link">Current Page: @Model.PageNumber / @Model.TotalPages</span>
            </li>

            @if (Model.HasNextPage)
            { 
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.PageNumber + 1)&searchString=@(ViewData["searchString"])">Next</a>
                </li>
             } 
        </ul>
    </nav>
</div>
<!-- Message Modal -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-@(TempData["MessageType"]?.ToString().ToLower()) text-white">
                <h5 class="modal-title" id="messageModalLabel">
                    <i class="bi bi-check-circle me-2"></i>Notification
                </h5>
                <!-- Fix close button style issue -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="filter: invert(1);"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="lead">@TempData["Message"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="closebtn" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>




<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirmation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Content will be set dynamically by JavaScript -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteButton">Confirm</button>
            </div>
        </div>
    </div>
</div>


<script>
    // First modify setDeleteInfo function to add operation type judgment
    function setDeleteInfo(id, name, type) {
        const modalTitle = document.getElementById('deleteModalLabel');
        const modalBody = document.querySelector('#deleteModal .modal-body');
        const confirmButton = document.getElementById('confirmDeleteButton');
        
        window.deleteId = id;
        window.locationtype = type;

        let operationText = '';
        switch (type) {
            case 1:
                operationText = "Delete";
                modalTitle.textContent = "Delete Confirmation";
                confirmButton.className = "btn btn-danger";
                break;
            case 2:
                operationText = "Unlock";
                modalTitle.textContent = "Unlock Confirmation";
                confirmButton.className = "btn btn-warning";
                break;
            case 3:
                operationText = "Clear Material";
                modalTitle.textContent = "Clear Confirmation";
                confirmButton.className = "btn btn-danger";
                break;
            case 4:
                operationText = "Reset Error Material";
                modalTitle.textContent = "Reset Confirmation";
                confirmButton.className = "btn btn-info";
                break;
        }

        modalBody.innerHTML = `Are you sure you want to perform ${operationText} operation on location <strong>"${name}"</strong>?`;
    }

    // Modify confirm button handling logic
    $(document).ready(function () {
        let deleteId;
        let locationtype;

        window.setDeleteInfo = setDeleteInfo; // Expose function to global scope

        $('#confirmDeleteButton').click(function () {
            $('#deleteModal').modal('hide');
            // Debug output to check deleteId and locationtype values
            console.log("deleteId:", window.deleteId);
            console.log("locationtype:", window.locationtype);
            // Set prompt message based on operation type
            let operationText = '';
            switch (window.locationtype) {
                case 1:
                    operationText = "Delete";
                    break;
                case 2:
                    operationText = "Reset Lock Status";
                    break;
                case 3:
                    operationText = "Clear Material";
                    break;
                case 4:
                    operationText = "Reset Error Material";
                    break;
            }
          
            $.ajax({
                url: '@Url.Action("DeleteConfirmed", "Location")',
                type: 'POST',
                data: {
                    Id: window.deleteId,
                    Type: window.locationtype,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    // 设置消息和类型
                    $('#messageModal .modal-body').text(response.message);
                    $('#messageModal .modal-header')
                        .removeClass('bg-success bg-danger')
                        .addClass(response.success ? 'bg-success' : 'bg-danger');

                    // 显示消息模态框
                    $('#messageModal').modal('show');

                    // 设置自动关闭并跳转
                    setTimeout(function () {
                        $('#messageModal').modal('hide');
                        window.location.href = '@Url.Action("Index", "Location")';
                    }, 2000);
                },
                error: function () {
                    $('#messageModal .modal-body').text(`${operationText} operation failed, please try again later.`);
                    $('#messageModal .modal-header')
                        .removeClass('bg-success bg-danger')
                        .addClass('bg-danger');
                    $('#messageModal').modal('show');
                }
            });
        });

        // Redirect when user manually closes message modal
        $('#messageModal').on('hidden.bs.modal', function () {
            window.location.href = '@Url.Action("Index", "Location")';
        });
    });
</script>



