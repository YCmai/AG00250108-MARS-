@model WarehouseManagementSystem.Models.User

@{
    ViewData["Title"] = "Permission Assignment";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-user-shield me-2"></i>Permission Assignment - @ViewBag.User.Username
                </h5>
                <a href="@Url.Action("Index")" class="btn btn-light">
                    <i class="fas fa-arrow-left me-1"></i>Back to User List
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row">
                <div class="col-md-8">
                    <form id="permissionForm">
                        <input type="hidden" name="userId" value="@ViewBag.User.Id" />
                        
                        <div class="card">
                            <div class="card-header">
                                <h6 class="mb-0">
                                    <i class="fas fa-list me-2"></i>Permission List
                                </h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    @foreach (var permission in ViewBag.AllPermissions)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input permission-checkbox" 
                                                       type="checkbox" 
                                                       name="permissionIds" 
                                                       value="@permission.Id" 
                                                       id="permission_@permission.Id"
                                                       @(ViewBag.UserPermissions.Contains(permission.Id) ? "checked" : "") />
                                                <label class="form-check-label" for="permission_@permission.Id">
                                                    <strong>@permission.Name</strong>
                                                    <br>
                                                    <small class="text-muted">@permission.Description</small>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i>Save Permission Settings
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
                
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="fas fa-info-circle me-2"></i>User Information
                            </h6>
                        </div>
                        <div class="card-body">
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Username:</strong></td>
                                    <td>@ViewBag.User.Username</td>
                                </tr>
                                <tr>
                                    <td><strong>Email:</strong></td>
                                    <td>@ViewBag.User.Email</td>
                                </tr>
                                <tr>
                                    <td><strong>Administrator:</strong></td>
                                    <td>
                                        @if (ViewBag.User.IsAdmin)
                                        {
                                            <span class="badge bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Status:</strong></td>
                                    <td>
                                        @if (ViewBag.User.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Disabled</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Created Time:</strong></td>
                                    <td>@ViewBag.User.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="fas fa-chart-pie me-2"></i>Permission Statistics
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="row text-center">
                                <div class="col-6">
                                    <div class="border-end">
                                        <h4 class="text-primary mb-0" id="totalPermissions">@ViewBag.AllPermissions.Count</h4>
                                        <small class="text-muted">Total Permissions</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <h4 class="text-success mb-0" id="assignedPermissions">@ViewBag.UserPermissions.Count</h4>
                                    <small class="text-muted">Assigned</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    $(document).ready(function() {
        // Update permission statistics
        function updatePermissionStats() {
            var total = $('.permission-checkbox').length;
            var assigned = $('.permission-checkbox:checked').length;
            
            $('#totalPermissions').text(total);
            $('#assignedPermissions').text(assigned);
        }

        // Listen for checkbox changes
        $('.permission-checkbox').on('change', function() {
            updatePermissionStats();
        });

        // Form submission
        $('#permissionForm').on('submit', function(e) {
            e.preventDefault();
            
            var userId = $('input[name="userId"]').val();
            var permissionIds = [];
            
            $('.permission-checkbox:checked').each(function() {
                permissionIds.push($(this).val());
            });

            // Show loading state
            var submitBtn = $(this).find('button[type="submit"]');
            var originalText = submitBtn.html();
            submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Saving...');

            $.ajax({
                url: '@Url.Action("AssignPermissions", "UserManagement")',
                type: 'POST',
                data: {
                    userId: userId,
                    permissionIds: permissionIds,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        // Show success message
                        var alertHtml = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                            '<i class="fas fa-check-circle me-2"></i>Permission assignment successful!' +
                            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                            '</div>';
                        $('.card-body').prepend(alertHtml);
                        
                        // Auto hide message
                        setTimeout(function() {
                            $('.alert-success').fadeOut();
                        }, 3000);
                    } else {
                        alert('Permission assignment failed: ' + (response.message || 'Unknown error'));
                    }
                },
                error: function(xhr, status, error) {
                    alert('Permission assignment failed: ' + error);
                },
                complete: function() {
                    // Restore button state
                    submitBtn.prop('disabled', false).html(originalText);
                }
            });
        });

        // Initialize statistics
        updatePermissionStats();
    });
</script>
